MEM0_BACKEND=local          # "local" or "cloud"

# Cloud backend
MEM0_API_KEY=mem0-xxxx
MEM0_HOST=https://api.mem0.ai
MEM0_ORG_ID=
MEM0_PROJECT_ID=

# Local backend
QDRANT_URL=localhost:6333   # leave blank to use the bundled qdrant path
MEM0_LOCAL_CONFIG=          # optional JSON overrides for MemoryConfig

OPENAI_API_KEY=sk-xxxx
DEFAULT_USER_ID=me
STATE_STORE=state.json
